<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <title>Unit Converter</title>
</head>
<body>
  <div class="container">
    <a href="index.html" class="breadcrumb"><i class="ph ph-arrow-left"></i> Back to Toolbox</a>
    <header class="tool-header">
      <div class="card-icon"><i class="ph ph-ruler"></i></div>
      <div class="tool-header-text">
        <h1>Unit Converter</h1>
        <p>Instantly convert length, weight, and temperature offline.</p>
      </div>
    </header>
    <main class="workspace">
      <div class="panel">
        <div class="panel-header"><h3>Conversion Tool</h3></div>
        <div class="panel-body">
          <div class="form-group">
            <label>Category</label>
            <select id="category" class="tz-select" onchange="updateUnits()">
              <option value="length">Length</option>
              <option value="weight">Weight</option>
              <option value="temp">Temperature</option>
            </select>
          </div>
          <div style="display: grid; grid-template-columns: 1fr auto 1fr; gap: 15px; align-items: end; margin-top: 1rem;">
            <div class="form-group" style="margin-bottom:0;">
              <label>From</label>
              <input type="number" id="inputValue" value="1" oninput="convert()" style="width: 100%; padding: 8px; margin-bottom: 5px;">
              <select id="unitFrom" class="tz-select" onchange="convert()"></select>
            </div>
            <div style="padding-bottom: 10px; color: var(--text-muted);"><i class="ph ph-arrows-left-right" style="font-size: 1.5rem;"></i></div>
            <div class="form-group" style="margin-bottom:0;">
              <label>To</label>
              <input type="text" id="outputValue" readonly style="width: 100%; padding: 8px; margin-bottom: 5px; background: var(--bg); border: 1px solid var(--border);">
              <select id="unitTo" class="tz-select" onchange="convert()"></select>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
  <script>
    const units = {
      length: { meters: 1, kilometers: 1000, centimeters: 0.01, miles: 1609.34, yards: 0.9144, feet: 0.3048, inches: 0.0254 },
      weight: { kilograms: 1, grams: 0.001, pounds: 0.453592, ounces: 0.0283495 },
      temp: { c: "Celsius", f: "Fahrenheit", k: "Kelvin" }
    };

    function updateUnits() {
      const cat = document.getElementById('category').value;
      const fromSel = document.getElementById('unitFrom');
      const toSel = document.getElementById('unitTo');
      fromSel.innerHTML = ''; toSel.innerHTML = '';
      
      for (const unit in units[cat]) {
        fromSel.add(new Option(unit.charAt(0).toUpperCase() + unit.slice(1), unit));
        toSel.add(new Option(unit.charAt(0).toUpperCase() + unit.slice(1), unit));
      }
      if(toSel.options.length > 1) toSel.selectedIndex = 1; // Default to different unit
      convert();
    }

    function convert() {
      const cat = document.getElementById('category').value;
      const val = parseFloat(document.getElementById('inputValue').value) || 0;
      const from = document.getElementById('unitFrom').value;
      const to = document.getElementById('unitTo').value;
      let result = 0;

      if (cat === 'temp') {
        let celsius = val;
        // Convert to Celsius first
        if (from === 'f') celsius = (val - 32) * 5/9;
        if (from === 'k') celsius = val - 273.15;
        // Convert from Celsius to Target
        if (to === 'c') result = celsius;
        if (to === 'f') result = (celsius * 9/5) + 32;
        if (to === 'k') result = celsius + 273.15;
      } else {
        // Convert to base unit, then divide by target unit
        const baseValue = val * units[cat][from];
        result = baseValue / units[cat][to];
      }
      
      document.getElementById('outputValue').value = Number.isInteger(result) ? result : result.toFixed(4);
    }

    // Init
    document.addEventListener('DOMContentLoaded', updateUnits);
  </script>
</body>
</html>
